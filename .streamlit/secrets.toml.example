# ============================================================================
# TYASA BI — Plantilla de secrets.toml
# ============================================================================
# 1. Copia este archivo como:  .streamlit/secrets.toml
# 2. Rellena los valores reales (ver CONFIGURACION.md para instrucciones)
# 3. NUNCA subas secrets.toml a git — ya está en .gitignore
# ============================================================================

# ── API de Google AI (Gemini) ────────────────────────────────────────────────
# Obtén tu key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY = "AIzaSy..."

# ── Credenciales de Google Cloud / BigQuery ──────────────────────────────────
# OPCIÓN A (recomendada): pega aquí el contenido del JSON de la cuenta de servicio
# Descarga el JSON desde GCP Console → IAM → Cuentas de servicio → Claves
[gcp_service_account]
type                        = "service_account"
project_id                  = "project-d0cf2519-d089-47d3-930"
private_key_id              = "PEGA_AQUI_private_key_id"
private_key                 = "-----BEGIN RSA PRIVATE KEY-----\nPEGA_AQUI_LA_CLAVE_PRIVADA\n-----END RSA PRIVATE KEY-----\n"
client_email                = "PEGA_AQUI@project-d0cf2519-d089-47d3-930.iam.gserviceaccount.com"
client_id                   = "PEGA_AQUI_client_id"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "PEGA_AQUI_client_x509_cert_url"

# ── OPCIÓN B (alternativa): ruta al archivo JSON descargado ─────────────────
# Descomenta si prefieres apuntar al archivo en lugar de embeber el contenido
# GOOGLE_APPLICATION_CREDENTIALS = "credentials.json"
